# ============================================
# MetallurgyTools — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# --- Clerk Authentication ---
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Google AI Studio ---
# Get from https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# --- iyzico Payment (Phase 1 — Turkey) ---
# Get from https://merchant.iyzipay.com
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET_KEY=your_iyzico_secret_key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Production: https://api.iyzipay.com

# --- App Config ---
# Resmi adres www subdomain'i. canonical/sitemap/robots/OG metadata
# bu URL'i kullanır. www / non-www uyumsuzluğu duplicate content yaratır.
NEXT_PUBLIC_APP_URL=https://www.metallurgytools.com

# --- Admin panel (GÜVENLİK) ---
# ADMIN_KEY: En az 24 karakter, rastgele. Örn: openssl rand -base64 32
# ADMIN_SESSION_SECRET: En az 32 byte. Cookie imzası için. Örn: openssl rand -base64 48
# Her iki değer de SADECE sunucuda kullanılır. NEXT_PUBLIC_ prefix'i ASLA EKLEME.
ADMIN_KEY=replace_with_openssl_rand_base64_32
ADMIN_SESSION_SECRET=replace_with_openssl_rand_base64_48

# --- Search Console / Bing Webmaster Verification ---
# Google Search Console → Ayarlar → Sahiplik Doğrulama → HTML etiketi yöntemi
# Sadece "content" değerini buraya koy (<meta ... content="XYZ"> içindeki XYZ)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
